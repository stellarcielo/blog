---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — stellarcielo`} description={post.data.description}>
  <article style="max-width: 700px; margin: 0 auto; padding: 5rem 2rem;">
    <a href="/blog" style="
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.1em;
      display: inline-block;
      margin-bottom: 2.5rem;
      transition: color 0.2s;
    " class="back-link">← BLOG</a>

    <div style="
      font-family: 'Space Mono', monospace;
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      margin-bottom: 0.8rem;
    ">
      {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
    </div>

    <h1 style="font-size: 2.2rem; font-weight: 800; margin: 0 0 1rem; color: var(--text); line-height: 1.2;">
      {post.data.title}
    </h1>

    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border);">
      {post.data.tags.map((tag: string) => (
        <span style="
          font-family: 'Space Mono', monospace;
          font-size: 0.62rem;
          padding: 0.2rem 0.6rem;
          border: 1px solid var(--border);
          color: var(--muted);
          letter-spacing: 0.08em;
        ">#{tag}</span>
      ))}
    </div>

    <div class="prose">
      <Content />
    </div>
  </article>

  <style>
    .back-link:hover {
      color: var(--accent) !important;
    }

    :global(.prose) {
      color: var(--text);
      font-size: 0.95rem;
      line-height: 1.9;
    }
    :global(.prose h2) {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 2.5rem 0 1rem;
      color: var(--text);
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    :global(.prose h3) {
      font-size: 1.15rem;
      font-weight: 600;
      margin: 2rem 0 0.8rem;
      color: var(--accent);
    }
    :global(.prose p) {
      margin: 0 0 1.2rem;
      color: var(--text);
    }
    :global(.prose a) {
      color: var(--accent);
      text-decoration: underline;
    }
    :global(.prose code) {
      font-family: 'Space Mono', monospace;
      font-size: 0.82em;
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 0.15em 0.4em;
      color: var(--accent);
    }
    :global(.prose pre) {
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 1.5rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }
    :global(.prose pre code) {
      background: none;
      border: none;
      padding: 0;
      font-size: 0.85rem;
      color: var(--text);
    }
    :global(.prose ul), :global(.prose ol) {
      padding-left: 1.5rem;
      margin: 0 0 1.2rem;
      color: var(--text);
    }
    :global(.prose li) { margin-bottom: 0.4rem; }
    :global(.prose blockquote) {
      border-left: 3px solid var(--accent);
      margin: 1.5rem 0;
      padding: 0.5rem 0 0.5rem 1.5rem;
      color: var(--muted);
      font-style: italic;
    }
  </style>
</Layout>
