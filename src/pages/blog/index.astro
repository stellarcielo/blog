---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — stellarcielo">
  <section style="max-width: 800px; margin: 0 auto; padding: 5rem 2rem;">
    <div style="font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 1rem;">
      // BLOG
    </div>
    <h1 style="font-size: 3rem; font-weight: 800; margin: 0 0 3rem; color: var(--text);">
      記事一覧
    </h1>

    {posts.length === 0 && (
      <p style="font-family: 'Space Mono', monospace; color: var(--muted); font-size: 0.85rem;">
        // 記事はまだありません。src/content/blog/ にMarkdownファイルを追加してください。
      </p>
    )}

    <div style="display: flex; flex-direction: column; gap: 0;">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} style="
          display: block;
          padding: 1.8rem 0;
          border-bottom: 1px solid var(--border);
          text-decoration: none;
          transition: padding-left 0.2s;
        " class="post-link">
          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
            <div style="flex: 1;">
              <h2 style="
                font-size: 1.15rem;
                font-weight: 700;
                color: var(--text);
                margin: 0 0 0.5rem;
                transition: color 0.2s;
              " class="post-title">{post.data.title}</h2>
              <p style="color: var(--muted); font-size: 0.85rem; margin: 0 0 0.8rem; line-height: 1.6;">
                {post.data.description}
              </p>
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                {post.data.tags.map((tag: string) => (
                  <span style="
                    font-family: 'Space Mono', monospace;
                    font-size: 0.62rem;
                    padding: 0.2rem 0.6rem;
                    border: 1px solid var(--border);
                    color: var(--muted);
                    letter-spacing: 0.08em;
                  ">#{tag}</span>
                ))}
              </div>
            </div>
            <div style="
              font-family: 'Space Mono', monospace;
              font-size: 0.68rem;
              color: var(--muted);
              white-space: nowrap;
              padding-top: 0.2rem;
            ">
              {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <style>
    .post-link:hover {
      padding-left: 1rem !important;
    }
    .post-link:hover .post-title {
      color: var(--accent) !important;
    }
  </style>
</Layout>
