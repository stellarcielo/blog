---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — stellarcielo">
  <section style="max-width: 600px; margin: 0 auto; padding: 5rem 2rem;">
    <div style="font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 1rem;">
      // CONTACT
    </div>
    <h1 style="font-size: 3rem; font-weight: 800; margin: 0 0 1rem; color: var(--text);">
      連絡先
    </h1>
    <p style="color: var(--muted); font-size: 0.95rem; line-height: 1.7; margin-bottom: 3rem;">
      お仕事のご相談・ご質問など、お気軽にご連絡ください。
    </p>

    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {[
        { label: 'GitHub', href: 'https://github.com/stellarcielo', value: 'github.com/stellarcielo' },
        //{ label: 'Discord Server', href: 'https://discord.gg/dnp62eujQX', value: 'R&D Center'},
        { label: 'MC Server Status', href: 'https://status.stellarcielo.com', value: 'Status'},
        //{ label: 'Twitter', href: 'https://twitter.com/yourusername', value: '@yourusername' },
        { label: 'Email', href: 'mailto:contact@stellarcielo.com', value: 'contact@stellarcielo.com' },
        { label: 'SchoolEmail', href: 'mailto:j23403@inc.kisarazu.ac.jp', value: 'j23403@inc.kisarazu.ac.jp'},
        { label: 'Crowdin', href: 'https://crowdin.com/profile/stellarcielo', value: 'stellarcielo'},
      ].map(item => (
        <a href={item.href} target="_blank" style="
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 1.2rem 1.5rem;
          background: var(--surface);
          border: 1px solid var(--border);
          text-decoration: none;
          transition: all 0.2s;
        " class="contact-link">
          <span style="
            font-family: 'Space Mono', monospace;
            font-size: 0.7rem;
            color: var(--muted);
            letter-spacing: 0.15em;
          ">{item.label}</span>
          <span style="
            font-size: 0.9rem;
            color: var(--text);
            transition: color 0.2s;
          " class="contact-value">{item.value}</span>
          <span style="color: var(--accent); font-size: 0.8rem;">→</span>
        </a>
      ))}
    </div>
  </section>

  <style>
    .contact-link:hover {
      border-color: var(--accent) !important;
      box-shadow: 0 0 20px rgba(0, 229, 255, 0.08) !important;
    }
    .contact-link:hover .contact-value {
      color: var(--accent) !important;
    }
  </style>
</Layout>
