---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — stellarcielo">
  <section style="max-width: 800px; margin: 0 auto; padding: 5rem 2rem;">
    <div style="font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--accent); letter-spacing: 0.2em; margin-bottom: 1rem;">
      // ABOUT.md
    </div>

    <h1 style="font-size: 3rem; font-weight: 800; margin: 0 0 3rem; color: var(--text);">
      自己紹介
    </h1>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">
      <div>
        <p style="color: var(--muted); line-height: 1.9; font-size: 0.95rem;">
          はじめまして。stellarcieloです。<br /><br />
          まだ学生のなんちゃってインフラエンジニアです。<br />
          Proxmoxなどを使って仮想化基盤を構築して、色々な検証やマインクラフトなどのサーバーの構築をしています。<br />
          UbiquitiさんのUnifi製品がとても好きです。<br /><br />
          ちなみにこのサイトはほぼclaudeくんに書いてもらいました。一回プロンプト書いて質問に答えただけですね。すごいです。もともとAstroの知識は少しあったもののここまで構築したことはありませんでした。
        </p>

        <div style="margin-top: 2.5rem;">
          <div style="font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--accent); letter-spacing: 0.15em; margin-bottom: 1rem;">
            // PROFILE
          </div>
          {[
            ['所属', '木更津工業高等専門学校'],
            ['学科', '情報工学科'],
            ['まあ使える言語', 'C, Java'],
            ['趣味', 'ゲーム, 自宅サーバー, 音楽'],
          ].map(([k, v]) => (
            <div style="display: flex; gap: 1rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border); font-size: 0.85rem;">
              <span style="font-family: 'Space Mono', monospace; color: var(--muted); min-width: 80px; font-size: 0.72rem;">{k}</span>
              <span style="color: var(--text);">{v}</span>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div style="font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--accent); letter-spacing: 0.15em; margin-bottom: 1rem;">
          // SKILLS
        </div>
        {[
          { name: 'Unifi Network', level: 80 },
          { name: 'Proxmox', level: 50 },
          { name: 'C', level: 40 },
          { name: 'Python', level: 30 },
          { name: 'Java', level: 20 },
          //{ name: 'Rust', level: 40 },
        ].map(skill => (
          <div style="margin-bottom: 1.2rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.4rem;">
              <span style="font-size: 0.82rem; color: var(--text);">{skill.name}</span>
              <span style="font-family: 'Space Mono', monospace; font-size: 0.7rem; color: var(--muted);">{skill.level}%</span>
            </div>
            <div style="height: 2px; background: var(--border); position: relative;">
              <div style={`width: ${skill.level}%; height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); box-shadow: 0 0 8px rgba(0, 229, 255, 0.4);`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
